{
  "name": "flux",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "cross-env NODE_ENV=production npm run build:server && npm run build && node server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
