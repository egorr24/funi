    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.7.4",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.511.0",
    "multer": "^1.4.5-lts.1",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.25",
    "pg": "^8.13.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.56.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
