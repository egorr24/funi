<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="#0a0a0c"
    android:layout_marginBottom="1dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/avatar_card"
        android:layout_width="52dp"
        android:layout_height="52dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#2d1b4d"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <TextView
            android:id="@+id/chat_avatar_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="NG"
            android:textColor="#a855f7"
            android:textStyle="bold"
            android:textSize="18sp"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/chat_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Chat Title"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/avatar_card"
        app:layout_constraintTop_toTopOf="@id/avatar_card" />

    <TextView
        android:id="@+id/chat_last_msg"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Last message preview goes here..."
        android:textColor="#888888"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/chat_title"
        app:layout_constraintTop_toBottomOf="@id/chat_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
