<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Flux" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#a855f7</item> <!-- Violet 500 -->
        <item name="colorPrimaryVariant">#7c3aed</item>
        <item name="colorOnPrimary">#ffffff</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#0a0a0c</item>
        <item name="colorSecondaryVariant">#1a1a1c</item>
        <item name="colorOnSecondary">#ffffff</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowBackground">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>

    <style name="Theme.Flux.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
